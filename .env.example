# Postgres (use the POOLED url for serverless on Vercel)
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
# openssl rand -hex 32
JWT_SECRET="change-me-to-a-long-random-secret"
# Cloudinary (image storage — URLs only, never base64). From your Cloudinary dashboard.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Platform Super Admin bootstrap. The first login at /superadmin/login with these
# credentials seeds the PlatformUser row; change the password afterwards is not yet
# wired, so pick a strong one. SUPERADMIN_NAME is optional (defaults to "Super Admin").
SUPERADMIN_EMAIL=""
SUPERADMIN_PASSWORD=""
SUPERADMIN_NAME=""
