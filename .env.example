# Postgres (use the POOLED url for serverless on Vercel)
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
# openssl rand -hex 32
JWT_SECRET="change-me-to-a-long-random-secret"
# Cloudinary (image storage — URLs only, never base64). From your Cloudinary dashboard.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Platform Super Admin bootstrap. The first login at /superadmin/login with these
# credentials seeds the PlatformUser row; change the password afterwards is not yet
# wired, so pick a strong one. SUPERADMIN_NAME is optional (defaults to "Super Admin").
SUPERADMIN_EMAIL=""
SUPERADMIN_PASSWORD=""
SUPERADMIN_NAME=""
# Google Sign-In. Create an OAuth 2.0 Client ID (type: Web application) at
# https://console.cloud.google.com/apis/credentials and add your site URL to
# "Authorized JavaScript origins" (e.g. https://your-app.vercel.app and
# http://localhost:3000). The SAME client id goes in both vars below.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_ID=""
# Password-reset email via Resend (https://resend.com). Verify a sending domain,
# create an API key, and set the From address to that domain.
RESEND_API_KEY=""
EMAIL_FROM="AM360 <no-reply@yourdomain.com>"
# Absolute site URL, used as a fallback for reset links when the request has no
# Origin header (normally auto-detected). e.g. https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=""
# Razorpay subscription payments (https://dashboard.razorpay.com). Key id + secret
# from Settings → API Keys. The key id is public (also exposed to the browser for
# checkout); the secret is server-only and signs/verifies payments.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""
