generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// snake_case scalar fields + string dates keep the JSON API contract stable. new

model Academy {
  id                   String  @id @default(uuid())
  name                 String
  logo_url             String?
  description          String  @default("")
  owner_id             String
  subscription_plan    String  @default("free")     // free | basic | pro | enterprise
  subscription_status  String  @default("active")   // active | expired
  subscription_started String?                       // start of current paid period
  subscription_expires String?                       // end of current paid period
  status               String  @default("active")   // active | suspended  (set by Super Admin)
  created_at           String
}

// One purchase of a paid plan (via Razorpay). Keeps full history; the Academy row
// holds the denormalized "current" plan/period for fast reads and limit checks.
model Subscription {
  id                  String  @id @default(uuid())
  academy_id          String
  plan_code           String                        // basic | pro | enterprise
  months              Int                            // 1..12
  amount              Float                          // total paid, in major units (₹)
  currency            String  @default("INR")
  start_date          String?
  end_date            String?
  status              String  @default("created")    // created | active | failed
  razorpay_order_id   String?
  razorpay_payment_id String?
  created_at          String

  @@index([academy_id, created_at])
}

// Platform-level Super Admin — sits above all academies. Seeded from env on first
// login (SUPERADMIN_EMAIL / SUPERADMIN_PASSWORD). Not tied to any academy.
model PlatformUser {
  id         String @id @default(uuid())
  email      String @unique
  name       String
  password   String
  created_at String
}

model Announcement {
  id         String  @id @default(uuid())
  title      String
  body       String
  academy_id String?                                 // null = broadcast to all academies
  created_by String
  created_at String

  @@index([academy_id])
}

model User {
  id                   String   @id @default(uuid())
  academy_id           String
  name                 String
  email                String   @unique
  username             String?  @unique
  password             String
  role                 String                        // owner | admin | trainer
  branch_id            String?                       // legacy primary branch
  branch_ids           String[] @default([])
  phone                String   @default("")
  address              String   @default("")
  photo_url            String?
  joining_date         String?
  status               String   @default("active")   // active | inactive
  must_change_password Boolean  @default(false)
  created_at           String

  @@index([academy_id, role])
}

model Branch {
  id            String  @id @default(uuid())
  academy_id    String
  name          String
  branch_code   String?
  address       String  @default("")
  phone         String  @default("")
  working_hours String  @default("")
  status        String  @default("active")           // active | inactive
  created_at    String

  @@index([academy_id])
}

model Student {
  id                String  @id @default(uuid())
  academy_id        String
  name              String
  parent_name       String  @default("")
  phone             String  @default("")
  alt_mobile        String  @default("")
  email             String  @default("")
  address           String  @default("")
  dob               String?
  gender            String?
  admission_date    String?
  branch_id         String
  batch             String  @default("")
  course            String  @default("")
  photo_url         String?
  emergency_contact String  @default("")
  medical_notes     String  @default("")
  monthly_fee       Float   @default(0)
  join_date         String
  notes             String  @default("")
  status            String  @default("active")
  created_at        String

  @@index([academy_id, branch_id])
  @@index([academy_id, status])
}

model Attendance {
  id         String @id @default(uuid())
  academy_id String
  branch_id  String
  student_id String
  date       String
  status     String                                  // present | absent | late
  marked_by  String
  marked_at  String

  @@index([academy_id, branch_id, date])
  @@index([academy_id, marked_by, date])
}

model ClassSession {
  id         String   @id @default(uuid())
  academy_id String
  branch_id  String
  date       String
  photos     String[] @default([])                   // Cloudinary URLs
  notes      String   @default("")
  marked_by  String
  marked_at  String

  @@unique([academy_id, branch_id, date])
}

model Fee {
  id          String    @id @default(uuid())
  academy_id  String
  student_id  String
  type        String    @default("monthly")          // monthly | admission
  amount      Float                                   // total due
  paid_amount Float     @default(0)
  month       String
  status      String    @default("pending")          // paid | pending | overdue
  due_date    String?
  note        String    @default("")
  created_at  String
  payments    Payment[]

  @@index([academy_id, student_id])
}

model Payment {
  id          String  @id @default(uuid())
  academy_id  String
  fee_id      String
  student_id  String
  amount      Float
  method      String  @default("cash")
  paid_date   String
  note        String  @default("")
  recorded_by String
  created_at  String
  fee         Fee     @relation(fields: [fee_id], references: [id], onDelete: Cascade)

  @@index([academy_id, student_id])
}

model Schedule {
  id          String  @id @default(uuid())
  academy_id  String
  branch_id   String
  trainer_id  String?
  title       String
  day_of_week Int
  start_time  String
  end_time    String
  notes       String  @default("")
  created_at  String

  @@index([academy_id, branch_id])
  @@index([academy_id, trainer_id])
}

model Plan {
  id            String  @id @default(uuid())
  code          String  @unique                    // free | premium
  name          String
  max_branches  Int     @default(-1)               // -1 = unlimited
  max_students  Int     @default(-1)
  max_trainers  Int     @default(-1)
  max_courses   Int     @default(-1)
  features      Json?                               // { reports, export, messaging, backup }
  price_monthly Float   @default(0)
  price_yearly  Float   @default(0)
  created_at    String
}

model Course {
  id          String @id @default(uuid())
  academy_id  String
  name        String
  description String @default("")
  status      String @default("active")            // active | inactive
  created_at  String

  @@index([academy_id, status])
}

model Batch {
  id         String  @id @default(uuid())
  academy_id String
  branch_id  String
  course_id  String?
  trainer_id String?
  name       String
  start_time String  @default("")
  end_time   String  @default("")
  status     String  @default("active")            // active | inactive
  created_at String

  @@index([academy_id, branch_id])
  @@index([academy_id, status])
}

model AuditLog {
  id         String @id @default(uuid())
  academy_id String
  actor_id   String
  actor_name String
  action     String                                  // e.g. student.create
  entity     String
  entity_id  String
  meta       Json?
  created_at String

  @@index([academy_id, created_at])
}

// One branch-wide WhatsApp broadcast (Notifications -> WhatsApp). Counts are
// snapshotted at send time so history never has to re-derive them from Student rows
// that may since have moved branch or been deleted.
model NotificationLog {
  id               String  @id @default(uuid())
  academy_id       String
  branch_id        String
  recipient_type   String                                // PARENTS | STUDENTS | BOTH
  message          String
  total_recipients Int     @default(0)
  // success_count / failed_count are what META ANSWERED AT SEND TIME — a 200 from the
  // Cloud API means "accepted for delivery", nothing more. The two counters below are
  // the truth, and they only arrive later on the webhook. They are deliberately separate:
  // collapsing them would make "11 ok" look like proof of delivery, which is exactly the
  // misreading that sent someone hunting for a bug that was never in this code.
  success_count    Int     @default(0)                   // accepted by Meta
  failed_count     Int     @default(0)                   // rejected by Meta, synchronously
  delivered_count  Int     @default(0)                   // confirmed on the recipient's phone
  undelivered_count Int    @default(0)                   // Meta gave up after accepting
  created_by       String
  created_at       String
  status           String  @default("completed")         // completed | partial | failed

  @@index([academy_id, created_at])
  @@index([academy_id, branch_id])
}

// One row per message handed to Meta, keyed by the `wamid` Meta returns on acceptance.
// This table exists solely so a delivery receipt has something to attach to: the Cloud
// API reports the real outcome (sent → delivered → read, or failed) only asynchronously,
// on the webhook, identifying the message by that id and nothing else. Without this row
// "accepted" can never become "delivered", and an undelivered message is indistinguishable
// from a delivered one — which is precisely the state this app was in before.
//
// `notification_id` is null for automatic birthday wishes, which have no broadcast row.
model WhatsAppMessage {
  id              String  @id @default(uuid())
  academy_id      String
  notification_id String?                                 // NotificationLog.id, null for birthday wishes
  student_id      String?
  phone           String
  wamid           String? @unique                         // Meta's id — the only handle a webhook has
  status          String  @default("accepted")            // accepted | sent | delivered | read | failed
  error_code      String  @default("")                    // Meta's numeric code, e.g. 131026
  error_detail    String  @default("")
  created_at      String
  updated_at      String

  @@index([academy_id, created_at])
  @@index([notification_id])
}

// Per-academy WhatsApp Business Cloud API credentials. One row per academy
// (academy_id is @unique, not just indexed) — every academy connects its OWN Meta
// WhatsApp Business account, so there is no global token anywhere in this app.
// access_token is AES-256-GCM encrypted (src/lib/crypto.ts) before it ever reaches
// this table; decrypt only happens server-side, inside WhatsAppIntegrationService.
model WhatsAppIntegration {
  id                   String  @id @default(uuid())
  academy_id           String  @unique
  business_account_id  String
  phone_number_id      String
  access_token         String                             // encrypted at rest
  verify_token         String  @default("")                // reserved for a future inbound webhook
  webhook_secret       String  @default("")                // reserved for a future inbound webhook
  display_phone_number String  @default("")
  business_name        String  @default("")
  status               String  @default("connected")       // connected | disconnected | invalid | expired
  connected_at         String
  last_validated_at    String?
  created_at           String
  updated_at           String
}

// Per-academy settings for automatic birthday wishes. One row per academy
// (academy_id @unique), created on first save. `enabled` defaults to FALSE on purpose:
// this feature messages real people without anyone pressing send, so it is strictly
// opt-in. `message` is a template with {name} / {academy} placeholders.
model BirthdayGreeting {
  id             String  @id @default(uuid())
  academy_id     String  @unique
  enabled        Boolean @default(false)
  recipient_type String  @default("BOTH")               // PARENTS | STUDENTS | BOTH
  message        String  @default("")
  last_run_date  String?                                 // YYYY-MM-DD of the last run
  created_at     String
  updated_at     String
}

// One row per (student, day, phone) that a birthday wish was attempted for. This table
// IS the idempotency guard, which is why the unique index is on the natural key and not
// on `id`: the row is claimed BEFORE the message goes out, so a retry, a double cron
// fire, or a dashboard load racing the cron all collide here instead of wishing someone
// a happy birthday four times. A failed send stays failed rather than being retried —
// double-messaging a customer is worse than missing one.
model BirthdayWish {
  id         String @id @default(uuid())
  academy_id String
  student_id String
  date       String                                      // YYYY-MM-DD the wish was for
  phone      String                                      // E.164, as sent
  status     String @default("sent")                     // sending | sent | failed
  run_id     String @default("")                         // which run owns this claim
  error      String @default("")
  created_at String

  @@unique([student_id, date, phone])
  @@index([academy_id, date])
}

// Password reset. We store only the SHA-256 hash of the emailed token, never the
// raw value, and expire it after ~1 hour. One-time use (marked `used`).
model PasswordResetToken {
  id         String  @id @default(uuid())
  user_id    String
  token_hash String
  expires_at String
  used       Boolean @default(false)
  created_at String

  @@index([user_id])
}
